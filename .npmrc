# Pack the file: dependency (typescript-plugin) into node_modules as a real directory instead of
# symlinking it. Two reasons, both load-bearing:
#
#  - vsce cannot put a symlink in the VSIX; `vsce package` dies with "not a file" on the symlinked
#    node_modules/metta-ts-typescript-plugin that npm's default (install-links=false) creates.
#  - the extension contributes that plugin by name (contributes.typescriptServerPlugins), and tsserver
#    resolves a plugin name against <extension>/node_modules, so the real files have to ship at that path.
#
# npm's default for this flipped across 9.x, so pinning it here is what makes a build reproducible rather
# than dependent on the contributor's npm version.
install-links=true
