{
  "name": "@metta-lsp/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Documentation and reference site for the MeTTa language server.",
  "scripts": {
    "docs:browser-ide": "node ../scripts/bundle-browser-ide.mjs",
    "docs:typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "docs:dev": "npm run docs:browser-ide && vitepress dev",
    "docs:build": "npm run docs:typecheck && npm run docs:browser-ide && vitepress build",
    "docs:preview": "vitepress preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lsp-client": "^6.2.5",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@lucide/vue": "^1.24.0",
    "@metta-ts/core": "^1.1.3",
    "@metta-ts/grapher": "^1.1.3",
    "codejar": "^4.2.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "gifenc": "^1.0.3",
    "vscode-languageserver-protocol": "^3.18.2"
  },
  "devDependencies": {
    "@shikijs/themes": "^2.5.0",
    "@types/node": "^22.20.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.3",
    "vue-tsc": "^3.3.7"
  }
}
