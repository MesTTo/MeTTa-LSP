{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noConsole": {
          "level": "error",
          "options": { "allow": ["warn", "error"] }
        },
        "noTemplateCurlyInString": "off"
      },
      "complexity": {
        "useOptionalChain": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": { "organizeImports": "on" }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/out",
      "!coverage",
      "!**/*.d.ts",
      "!package-lock.json",
      "!syntaxes",
      "!snippets",
      "!docs-site",
      "!**/*.svg"
    ]
  },
  "overrides": [
    {
      "includes": ["src/cli/**", "**/*.test.ts", "**/*.spec.ts", "test/**", "scripts/**"],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" }
        }
      }
    }
  ]
}
